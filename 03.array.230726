#include<stdio.h>
int main(){
    int arr[100],n,ele,pos;
    printf("Enter the no. of elements:");
    scanf("%d",&n);
    printf("Enter the elements:");
    for(int i=0;i<n;i++){
        scanf("%d",&arr[i]);

        
    }
    printf("Enter the element:");
    scanf("%d",&ele);
    printf("Enter the position:");
    scanf("%d",&pos);
    for(int i=n;i>=pos;i--){
        arr[i]=arr[i-1];
        
    }
    arr[pos-1]=ele;
        n++;
   




    for(int i=0;i<n;i++){
        printf("%d ",arr[i]);
 
    }
    printf("Enter the position:");
    scanf("%d",&pos);
    for(int i=pos-1;i<n-1;i++){
        arr[i]=arr[i+1];
    }
    n--;
    for(int i=0;i<n;i++){
        printf("%d",arr[i]);
    }
    return 0;
}

